DATABASE_URL=postgresql://threatlens:threatlens@localhost:5432/threatlens
PORT=4000
JWT_SECRET=change-me-to-a-long-random-string
JWT_EXPIRES_IN=7d
CORS_ORIGIN=http://localhost:5173

# AI (optional — improves analyst narrative)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash

# Email / OTP — use console for local demos (logs code to API terminal)
EMAIL_PROVIDER=console
OTP_EXPIRY_MINUTES=10
OTP_RESEND_COOLDOWN_SECONDS=60
OTP_MAX_SENDS_PER_EMAIL_HOUR=8

# SMTP (when EMAIL_PROVIDER=smtp)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=ThreatLens <no-reply@threatlens.local>

# Resend (when EMAIL_PROVIDER=resend)
RESEND_API_KEY=
RESEND_FROM=ThreatLens <onboarding@resend.dev>
